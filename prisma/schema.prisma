// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Donation {
  id              String   @id @default(cuid())
  donorEmail      String
  donorName       String?
  donorAnonymous  Boolean  @default(false)
  amount          Float
  currency        String   @default("USD")
  paymentMethod   String   @default("card")
  paymentStatus   String   @default("pending")
  transactionRef  String   @unique
  stripeSessionId String?
  perkId          String?
  isRecurring     Boolean  @default(false)
  recurringFreq   String?
  message         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Application {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String
  phone             String?
  birthdate         String?
  gender            String?
  pronoun           String?
  citizenship       String?
  dualCitizenship   String?
  address           String?
  city              String?
  state             String?
  postalCode        String?
  country           String?
  howHeard          String?
  applicationCycle  String?
  concentration     String?
  currentlyEnrolled String?
  schoolName        String?
  schoolCountry     String?
  schoolCity        String?
  enrollmentStart   String?
  enrollmentEnd     String?
  gradingScale      String?
  gpa               String?
  maxGpa            String?
  satMath           String?
  satReading        String?
  actScore          String?
  isTestOptional    Boolean  @default(false)
  accomplishments   String?  // JSON string
  personalStatement String?
  missionStatement  String?
  applyingForAid    String?
  householdIncome   String?
  dependents        String?
  status            String   @default("submitted")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  area      String?  // e.g. "General Enquiry", "Donations", "Partnerships"
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // e.g. "blog", "homepage", "footer"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LMSUser {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatarUrl     String?
  role          String   @default("student") // "student", "tutor", "admin"
  bio           String?
  enrolledAt    DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  enrollments   Enrollment[]
  assignments   AssignmentSubmission[]
  aiSessions    AITutorSession[]
  givenFeedback TutorFeedback[]
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  code        String   @unique  // e.g. "ART-101"
  category    String   // e.g. "Synthetic Intelligence", "Ethics"
  level       String   @default("introductory") // introductory, intermediate, advanced
  thumbnail   String?
  status      String   @default("active") // active, archived, draft
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  modules     Module[]
  enrollments Enrollment[]
  assignments Assignment[]
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  type        String   @default("content") // content, live_session, workshop, assessment
  contentUrl  String?
  duration    String?  // e.g. "45 min"
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  content     String?  // Markdown or HTML content
  type        String   @default("video") // video, reading, quiz, live_session, interactive
  videoUrl    String?
  duration    String?
  order       Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  role        String    @default("student") // student, tutor
  progress    Float     @default(0) // 0-100 percentage
  status      String    @default("active") // active, completed, dropped
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  user        LMSUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Assignment {
  id          String    @id @default(cuid())
  courseId    String
  moduleId    String?
  title       String
  description String
  type        String    @default("essay") // essay, quiz, project, peer_review, live_demo
  dueDate     DateTime?
  maxScore    Int       @default(100)
  status      String    @default("open") // open, closed, graded
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  userId       String
  content      String   // JSON string for flexible submission data
  grade        Float?
  feedback     String?
  aiFeedback   String?  // AI-generated initial feedback
  status       String   @default("submitted") // submitted, ai_reviewed, tutor_reviewed, graded
  submittedAt  DateTime @default(now())
  gradedAt     DateTime?
  user         LMSUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  tutorFeedback TutorFeedback[]
}

model AITutorSession {
  id          String   @id @default(cuid())
  userId      String
  courseId    String?
  context     String?  // what topic/session the AI tutor is helping with
  messages    String   // JSON array of {role, content} messages
  summary     String?  // AI-generated session summary
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        LMSUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutorFeedback {
  id           String   @id @default(cuid())
  tutorId      String
  submissionId String
  content      String
  rating       Int?     // tutor's assessment of AI feedback quality
  createdAt    DateTime @default(now())
  tutor        LMSUser  @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}
